{
  "name": "fluixi-icons-generator",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "clean":         "tsx scripts/clean-generated-files.ts",
    "fetch:icons":   "tsx scripts/fetch-icons.ts",
    "copy-icons":    "tsx scripts/copy-icons.ts",
    "generate":      "tsx scripts/run-generate.ts",
    "sprites":       "tsx scripts/generate-sprites.ts",
    "bundle":        "tsx scripts/generate-cdn-bundle.ts",
    "copy-registry": "tsx scripts/copy-registry.ts",
    "build:ts":      "tsx scripts/build-ts.ts",
    "build:api":     "tsx scripts/build-icons-api.ts",
    "build:jsx":     "tsx scripts/build-icons-jsx.ts",
    "build":         "pnpm run build:ts && pnpm run build:api && pnpm run build:jsx",
    "format":        "prettier --write \"**/*.{ts,js,json,md}\" --ignore-path .gitignore",
    "format:check":  "prettier --check \"**/*.{ts,js,json,md}\" --ignore-path .gitignore",
    "changeset":     "changeset",
    "version":       "changeset version",
    "release":       "pnpm run build && pnpm run sprites && pnpm run bundle && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli":              "^2.31.0",
    "@rollup/plugin-commonjs":      "^28.0.6",
    "@rollup/plugin-json":          "^6.1.0",
    "@rollup/plugin-node-resolve":  "^16.0.2",
    "@rollup/plugin-terser":        "^0.4.4",
    "@rollup/plugin-typescript":    "^12.1.4",
    "@types/node":                  "^24.7.0",
    "@types/react":                 "^19.0.0",
    "@xmldom/xmldom":               "^0.8.11",
    "fast-glob":                    "^3.3.3",
    "picocolors":                   "^1.1.1",
    "prettier":                     "^3.6.2",
    "rollup":                       "^4.52.4",
    "rollup-plugin-dts":            "^6.2.3",
    "svgo":                         "^3.1.0",
    "tsx":                          "^4.20.6",
    "typescript":                   "^5.9.3"
  }
}
