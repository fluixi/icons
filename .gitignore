node_modules
packages/*/dist
packages/*/node_modules

# Local auth token — never commit (CI uses GITHUB_TOKEN via setup-node)
.npmrc.local

# Generated icon TypeScript modules — rebuilt by CI via `pnpm generate`
packages/icons/*/src/icons/
tmp-icons/
icons/

# Generated aggregator files (rebuilt from icons/)
packages/icons/*/src/all.ts

# Raw SVGs for fetched sets — re-fetched in CI (`pnpm fetch:icons` + `copy-icons`).
# icon-internal is our own set: its SVGs are the committed source of truth, so
# they are explicitly re-included below.
packages/icons/*/icons/
!packages/icons/icon-internal/icons/
!packages/icons/icon-internal/icons/**

# CDN bundles (too large for git — generated by `pnpm bundle`)
cdn/

# Sprite output (generated by `pnpm sprites`)
sprites/

# Build cache
.tscache/
*.tsbuildinfo
.rollup.cache.json
